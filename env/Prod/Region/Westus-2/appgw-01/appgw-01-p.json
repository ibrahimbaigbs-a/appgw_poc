{
    "name": "agw-prod-01",
    "resource_group_name": "primaryagw-rg",
    "location": "westus2",
    "app_gateway_subnet_id": "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/primaryagw-rg/providers/Microsoft.Network/virtualNetworks/p-agq-vnet/subnets/agw-snet-01",
    "public_ip_name": "pip-agw-prod-01",
    "app_gateway_zones": [
        "1",
        "2",
        "3"
    ],
    "public_ip_zones": [
        "1",
        "2",
        "3"
    ],
    "managed_identities": {
        "user_assigned_resource_ids": [
            "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourcegroups/MigrationRG/providers/Microsoft.ManagedIdentity/userAssignedIdentities/testumi"
        ]
    },
    "frontend_ip_configurations": {
        "public_default": {
            "name": "agw-prod-01-feip",
            "use_created_public_ip": true
        },
        "private_internal": {
            "name": "agw-prod-01-feip-private",
            "subnet_id": "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/primaryagw-rg/providers/Microsoft.Network/virtualNetworks/p-agq-vnet/subnets/agw-snet-01",
            "private_ip_address": "192.168.0.5",
            "private_ip_address_allocation": "Static"
        }
    },
    "backend_ip_addresses": [],
    "frontend_ports": {
        "http": {
            "name": "port-80",
            "port": 80
        },
        "https": {
            "name": "port-443",
            "port": 443
        }
    },
    "backend_address_pools": {
        "web_pool": {
            "name": "pool-web"
        }
    },
    "backend_http_settings": {
        "web_http": {
            "name": "bhs-web-http",
            "port": 80,
            "protocol": "Http",
            "cookie_based_affinity": "Disabled",
            "request_timeout": 30
        }
    },
    "http_listeners": {
        "http_listener": {
            "name": "lst-http",
            "frontend_port_name": "port-80",
            "frontend_ip_configuration_name": "agw-prod-01-feip",
            "protocol": "Http",
            "host_names": [
                "app.contoso.com"
            ]
        },
        "http_listener_private": {
            "name": "lst-http-private",
            "frontend_port_name": "port-80",
            "frontend_ip_configuration_name": "agw-prod-01-feip-private",
            "protocol": "Http",
            "host_names": [
                "internal.app.contoso.com"
            ]
        },
        "https_listener": {
            "name": "lst-https",
            "frontend_port_name": "port-443",
            "frontend_ip_configuration_name": "agw-prod-01-feip",
            "protocol": "Https",
            "ssl_certificate_name": "web-cert",
            "host_names": [
                "app.contoso.com"
            ]
        }
    },
    "request_routing_rules": {
        "web_rule": {
            "name": "rr-web",
            "rule_type": "Basic",
            "http_listener_name": "lst-http",
            "backend_address_pool_name": "pool-web",
            "backend_http_settings_name": "bhs-web-http",
            "priority": 100
        },
        "web_rule_private": {
            "name": "rr-web-private",
            "rule_type": "Basic",
            "http_listener_name": "lst-http-private",
            "backend_address_pool_name": "pool-web",
            "backend_http_settings_name": "bhs-web-http",
            "priority": 110
        }
    },
    "probes": {
        "web": {
            "name": "probe-web",
            "protocol": "Http",
            "path": "/health",
            "interval": 30,
            "timeout": 30,
            "unhealthy_threshold": 3,
            "pick_host_name_from_backend_http_settings": true,
            "match": {
                "status_code": [
                    "200-399"
                ]
            }
        }
    },
    "host_names": [
        "app.contoso.com"
    ],
    "ssl_certificate_key_vault_secret_id": "https://your-keyvault-name.vault.azure.net/secrets/your-cert-name",
    "log_analytics_workspace_id": null,
    "tags": {
        "environment": "prod",
        "role": "primary",
        "workload": "network-ingress",
        "managedBy": "terraform"
    }
