{
    "name": "agw-prod-01",
    "resource_group_name": "primaryagw-rg",
    "location": "westus2",
    "app_gateway_subnet_id": "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/primaryagw-rg/providers/Microsoft.Network/virtualNetworks/p-agq-vnet/subnets/agw-snet-01",
    "public_ip_name": "pip-agw-prod-01",
    "app_gateway_zones": [
        "1",
        "2",
        "3"
    ],
    "public_ip_zones": [
        "1",
        "2",
        "3"
    ],
    "managed_identities": {
        "user_assigned_resource_ids": [
            "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/MigrationRG/providers/Microsoft.ManagedIdentity/userAssignedIdentities/testumi"
        ]
    },
    "frontend_ip_configurations": {
        "public_default": {
            "name": "agw-prod-01-feip",
            "use_created_public_ip": true
        },
        "private_internal": {
            "name": "agw-prod-01-feip-private",
            "subnet_id": "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/primaryagw-rg/providers/Microsoft.Network/virtualNetworks/p-agq-vnet/subnets/agw-snet-01",
            "private_ip_address": "192.168.0.5",
            "private_ip_address_allocation": "Static"
        }
    },
    "frontend_ports": {
        "http": {
            "name": "port-80",
            "port": 80
        },
        "https": {
            "name": "port-443",
            "port": 443
        }
    },
    "ssl_certificates": {
        "cert_web_default": {
            "name": "appgw-test-cert-02",
            "key_vault_secret_id": "https://safewaykvwestus.vault.azure.net/secrets/appgw-test-cert-02"
        },
        "cert_web_alt": {
            "name": "appgw-test-cert01",
            "key_vault_secret_id": "https://safewaykvwestus.vault.azure.net/secrets/appgw-test-cert01"
        }
    },
    "listener_bundles": {
        "public_https": {
            "listener": {
                "name": "lst-http",
                "frontend_port_name": "port-443",
                "frontend_ip_configuration_name": "agw-prod-01-feip",
                "protocol": "Https",
                "ssl_certificate_name": "appgw-test-cert-02",
                "require_sni": true,
                "host_names": [
                    "app.contoso.com"
                ]
            },
            "backend_address_pool": {
                "name": "pool-web-public"
            },
            "backend_http_settings": {
                "name": "bhs-web-public",
                "port": 80,
                "protocol": "Http",
                "cookie_based_affinity": "Disabled",
                "request_timeout": 30
            },
            "probe": {
                "name": "probe-web-public",
                "protocol": "Http",
                "host": "app.contoso.com",
                "path": "/health",
                "interval": 30,
                "timeout": 30,
                "unhealthy_threshold": 3,
                "match": {
                    "status_code": [
                        "200-399"
                    ]
                }
            },
            "request_routing_rule": {
                "name": "rr-web",
                "rule_type": "Basic",
                "priority": 100
            }
        },
        "private_http": {
            "listener": {
                "name": "lst-http-private",
                "frontend_port_name": "port-80",
                "frontend_ip_configuration_name": "agw-prod-01-feip-private",
                "protocol": "Http",
                "host_names": [
                    "internal.app.contoso.com"
                ]
            },
            "backend_address_pool": {
                "name": "pool-web-private"
            },
            "backend_http_settings": {
                "name": "bhs-web-private",
                "port": 80,
                "protocol": "Http",
                "cookie_based_affinity": "Disabled",
                "request_timeout": 30
            },
            "probe": {
                "name": "probe-web-private",
                "protocol": "Http",
                "host": "internal.app.contoso.com",
                "path": "/health",
                "interval": 30,
                "timeout": 30,
                "unhealthy_threshold": 3,
                "match": {
                    "status_code": [
                        "200-399"
                    ]
                }
            },
            "request_routing_rule": {
                "name": "rr-web-private",
                "rule_type": "Basic",
                "priority": 110
            }
        },
        "public_https_alt": {
            "listener": {
                "name": "lst-https",
                "frontend_port_name": "port-443",
                "frontend_ip_configuration_name": "agw-prod-01-feip",
                "protocol": "Https",
                "ssl_certificate_name": "appgw-test-cert01",
                "require_sni": true,
                "host_names": [
                    "app2.contoso.com"
                ]
            },
            "backend_address_pool": {
                "name": "pool-web-alt"
            },
            "backend_http_settings": {
                "name": "bhs-web-alt",
                "port": 80,
                "protocol": "Http",
                "cookie_based_affinity": "Disabled",
                "request_timeout": 30
            },
            "probe": {
                "name": "probe-web-alt",
                "protocol": "Http",
                "host": "app2.contoso.com",
                "path": "/health",
                "interval": 30,
                "timeout": 30,
                "unhealthy_threshold": 3,
                "match": {
                    "status_code": [
                        "200-399"
                    ]
                }
            },
            "request_routing_rule": {
                "name": "rr-web-https-alt",
                "rule_type": "Basic",
                "priority": 120
            }
        }
    },
    "autoscale_configuration": {
        "min_capacity": 3,
        "max_capacity": 5
    },
    "log_analytics_workspace_id": null,
    "tags": {
        "environment": "prod",
        "role": "primary",
        "workload": "network-ingress",
        "managedBy": "terraform"
    }
