{
    "name": "agw-prod-01",
    "resource_group_name": "secondaryagw-rg",
    "location": "westus",
    "app_gateway_subnet_id": "/subscriptions/5ade8a7e-f940-457e-9b4e-65bd6e1d0a29/resourceGroups/secondaryagw-rg/providers/Microsoft.Network/virtualNetworks/s-agw-vnet/subnets/agw-snet-01",
    "public_ip_name": "pip-agw-prod-01",
    "app_gateway_zones": null,
    "public_ip_zones": null,
    "frontend_ip_configurations": {
        "public_default": {
            "name": "agw-prod-01-feip",
            "use_created_public_ip": true
        }
    },
    "frontend_ports": {
        "http": {
            "name": "port-80",
            "port": 80
        },
        "https": {
            "name": "port-443",
            "port": 443
        }
    },
    "listener_bundles": {
        "public_http": {
            "listener": {
                "name": "lst-http",
                "frontend_port_name": "port-80",
                "frontend_ip_configuration_name": "agw-prod-01-feip",
                "protocol": "Http",
                "host_names": [
                    "app.contoso.com"
                ]
            },
            "backend_address_pool": {
                "name": "pool-web",
                "ip_addresses": [
                    "10.10.1.10",
                    "10.10.1.11"
                ]
            },
            "backend_http_settings": {
                "name": "bhs-web-http",
                "port": 80,
                "protocol": "Http",
                "cookie_based_affinity": "Disabled",
                "request_timeout": 30
            },
            "probe": {
                "name": "probe-web",
                "protocol": "Http",
                "path": "/health",
                "interval": 30,
                "timeout": 30,
                "unhealthy_threshold": 3,
                "pick_host_name_from_backend_http_settings": true,
                "match": {
                    "status_code": [
                        "200-399"
                    ]
                }
            },
            "request_routing_rule": {
                "name": "rr-web",
                "rule_type": "Basic",
                "priority": 100
            }
        }
    },
    "autoscale_configuration": {
        "min_capacity": 3,
        "max_capacity": 5
    },
    "log_analytics_workspace_id": null,
    "tags": {
        "environment": "prod",
        "role": "secondary",
        "workload": "network-ingress",
        "managedBy": "terraform"
    }
}