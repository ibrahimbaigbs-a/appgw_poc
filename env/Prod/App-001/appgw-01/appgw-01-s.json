        }
    },
    "backend_ip_addresses": [],
    "frontend_ports": {
        "http": {
            "name": "port-80",
            "port": 80
        },
        "https": {
            "name": "port-443",
            "port": 443
        }
    },
    "backend_address_pools": {
        "web_pool": {
            "name": "pool-web",
            "ip_addresses": [
                "10.10.1.10",
                "10.10.1.11"
            ]
        }
    },
    "backend_http_settings": {
        "web_http": {
            "name": "bhs-web-http",
            "port": 80,
            "protocol": "Http",
            "cookie_based_affinity": "Disabled",
            "request_timeout": 30
        }
    },
    "http_listeners": {
        "http_listener": {
            "name": "lst-http",
            "frontend_port_name": "port-80",
            "frontend_ip_configuration_name": "agw-prod-01-feip",
            "protocol": "Http",
            "host_names": [
                "app.contoso.com"
            ]
        }
    },
    "request_routing_rules": {
        "web_rule": {
            "name": "rr-web",
